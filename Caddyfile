# Proxy reverso com HTTPS automático (Let's Encrypt).
# Requer: domínio (SITE_DOMAIN) apontando para o IP da VPS e portas 80/443 abertas.
# Para incluir o www, troque a 1ª linha por:  {$SITE_DOMAIN}, www.{$SITE_DOMAIN} {
{$SITE_DOMAIN} {
	encode gzip zstd

	# API → container api:8080
	handle /api/* {
		reverse_proxy api:8080
	}

	# Demais rotas → frontend (vite preview) web:3000
	handle {
		reverse_proxy web:3000
	}
}
