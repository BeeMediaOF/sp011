# ============================================================
# SBC Agora — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env com dados reais
# ============================================================

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/sbcagora

# Segurança de sessão/token (gere uma string aleatória longa)
SESSION_SECRET=troque-por-uma-string-aleatoria-longa-e-segura

# URL pública da aplicação
APP_URL=https://seudominio.com.br

# Ambiente (development | production)
NODE_ENV=production

# Origem permitida para CORS (URL do frontend)
CORS_ORIGIN=https://seudominio.com.br

# Credenciais do admin inicial (usadas no seed)
ADMIN_DEFAULT_EMAIL=admin@sbcagora.com.br
ADMIN_DEFAULT_PASSWORD=troque-esta-senha-imediatamente

# Chave de API para webhooks externos (opcional)
WEBHOOK_API_KEY=

# Chave de API Perplexity (busca de notícias com IA)
PERPLEXITY_API_KEY=

# Nível de log (fatal | error | warn | info | debug | trace)
LOG_LEVEL=info

# Porta do servidor (padrão: 5000)
PORT=5000
