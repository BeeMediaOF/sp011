# ============================================================
# SBC Agora — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com dados reais.
# ============================================================

# ── Banco de dados (Supabase PostgreSQL) ───────────────────
# Use a string do "Session pooler" do Supabase (IPv4). A senha precisa ter os
# caracteres especiais codificados na URL (ex: @ -> %40, # -> %23).
# O app prioriza SUPABASE_DATABASE_URL; se ausente, usa DATABASE_URL.
SUPABASE_DATABASE_URL=postgresql://postgres.SEU_REF:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/sbcagora

# ── Supabase Storage (uploads de imagens/vídeos) ───────────
# Crie um bucket no Supabase (Storage) e informe os dados abaixo.
# A service_role key fica em: Project Settings → API → service_role (secreta!).
# Se SUPABASE_URL/SERVICE_ROLE_KEY não forem definidas, os uploads caem para
# o disco local (apenas para desenvolvimento).
SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# ── Segurança ──────────────────────────────────────────────
# Gere uma string aleatória longa. Em produção é OBRIGATÓRIA (o app não sobe sem).
# Mantenha o mesmo valor sempre — trocar invalida todas as sessões/tokens.
SESSION_SECRET=troque-por-uma-string-aleatoria-longa-e-segura

# ── URLs públicas ──────────────────────────────────────────
# Domínio público do site (usado em links de redes sociais e e-mails).
APP_URL=https://seudominio.com.br
SITE_URL=https://seudominio.com.br

# Origens permitidas no CORS (separe por vírgula). Em produção, defina a URL
# pública do frontend; sem isso, requisições cross-origin são bloqueadas.
ALLOWED_ORIGINS=https://seudominio.com.br

# ── Ambiente / servidor ────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── Admin inicial (seed) ───────────────────────────────────
ADMIN_DEFAULT_EMAIL=admin@sbcagora.com.br
ADMIN_DEFAULT_PASSWORD=troque-esta-senha-imediatamente

# ── IA (geração/curadoria de notícias) ─────────────────────
# Na VPS use a chave direta do Google AI Studio (modo "gemini_direct").
# As variáveis AI_INTEGRATIONS_* são exclusivas do proxy do Replit — ignore-as fora dele.
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ── Web Push (notificações) ────────────────────────────────
# Reaproveite as chaves VAPID já existentes do projeto.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── E-mail (SMTP) ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Webhooks externos (opcional) ───────────────────────────
WEBHOOK_API_KEY=
